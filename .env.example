# The public URL of your deployed site (no trailing slash).
# Used for sitemap, robots.txt, and OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Resend API key for the contact form.
# Get one at https://resend.com — free tier is sufficient for low volume.
# Without this key the form works in dev but won't send real emails.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
